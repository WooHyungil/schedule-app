rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isEmailOnlyUserId(userId) {
      return userId.matches('^local_[A-Za-z0-9_-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isEmailOnlyUserId(userId);

      match /{document=**} {
        allow read, write: if isOwner(userId) || isEmailOnlyUserId(userId);
      }
    }
  }
}
